@model IEnumerable<DAQCom.Models.MonAn>

@{
    ViewBag.Title = "Quản lý món ăn";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    // Lấy tên loại món đang xem để hiển thị lên tiêu đề
    string currentLoai = ViewBag.CurrentLoai as string;
    string title = string.IsNullOrEmpty(currentLoai) ? "Tất cả món ăn" : "Danh sách " + currentLoai;
}

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="@Url.Action("Index", "HomeAdmin")" class="text-decoration-none text-secondary small">
                <i class="fa fa-arrow-left"></i> Quay lại Dashboard
            </a>
            <h2 class="text-primary fw-bold mt-1">@title</h2>
            <p class="text-muted small mb-0">Hiện có: @(Model != null ? Model.Count() : 0) món</p>
        </div>

        <button class="btn btn-success btn-popup shadow-sm" data-url="@Url.Action("Create", "MonAnAdmin")">
            <i class="fa fa-plus me-2"></i> Thêm Món Mới
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên món</th>
                        <th>Giá bán</th>
                        <th>Loại món</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="rounded border overflow-hidden" style="width:50px; height:50px;">
                                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                                        {
                                            <img src="~/Content/Images/@item.HinhAnh" style="width:100%; height:100%; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No IMG</span>
                                        }
                                    </div>
                                </td>
                                <td class="fw-bold text-dark">@item.TenMon</td>
                                <td class="text-danger fw-bold">@string.Format("{0:N0} đ", item.Gia)</td>
                                <td>
                                    <span class="badge bg-info text-dark bg-opacity-25 border border-info">@item.LoaiMon</span>
                                </td>

                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary btn-popup me-2"
                                            title="Sửa món này"
                                            data-url="@Url.Action("Edit", "MonAnAdmin", new { id = item.MaMon })">
                                        <i class="fa fa-edit"></i> Sửa
                                    </button>

                                    <a href="@Url.Action("Delete", "MonAnAdmin", new { id = item.MaMon })"
                                       class="btn btn-sm btn-outline-danger"
                                       title="Xóa món này"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa món @item.TenMon không?');">
                                        <i class="fa fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa fa-box-open fa-2x mb-2"></i><br />
                                Chưa có món ăn nào trong danh mục này.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="modalContent">
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Xử lý sự kiện click nút Popup (Thêm/Sửa)
            $('body').on('click', '.btn-popup', function (e) {
                e.preventDefault();
                var url = $(this).data('url');

                // Gọi AJAX để lấy form
                $.get(url, function (data) {
                    $('#modalContent').html(data);
                    $('#actionModal').modal('show');
                });
            });
        });
    </script>
} 