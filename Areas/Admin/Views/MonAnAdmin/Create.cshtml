
@model DAQCom.Models.MonAn
@{ Layout = null; }

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title">Thêm Món Ăn Mới</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    @using (Html.BeginForm("Create", "MonAnAdmin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Tên món</label>
                @Html.TextBoxFor(m => m.TenMon, new { @class = "form-control", required = "required" })
            </div>
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Loại món</label>
                @Html.DropDownListFor(m => m.LoaiMon, (SelectList)ViewBag.LoaiMonList, new { @class = "form-select" })
            </div>
        </div>

        <div class="mb-3">
            <label class="fw-bold">Giá bán</label>
            @Html.TextBoxFor(m => m.Gia, new { @class = "form-control", type = "number" })
        </div>

        <div class="mb-3">
            <label class="fw-bold">Hình ảnh</label>
            <input type="file" name="HinhAnhUpload" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="fw-bold">Mô tả</label>
            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 3 })
        </div>

        <div class="text-end">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            <button type="submit" class="btn btn-primary">Lưu lại</button>
        </div>
    }
</div>