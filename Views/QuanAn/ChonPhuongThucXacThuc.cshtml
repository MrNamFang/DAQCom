@{
    ViewBag.Title = "Chọn phương thức xác thực";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0" style="border-radius: 15px;">
                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold text-success mb-4">XÁC THỰC TÀI KHOẢN</h3>
                    <p class="text-muted mb-4">Vui lòng chọn phương thức để nhận mã OTP.</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    @using (Html.BeginForm("GuiMaOTP", "QuanAn", FormMethod.Post))
                    {
                        <div class="d-grid gap-3">
                            <button type="submit" name="phuongThuc" value="Email" class="btn btn-outline-success btn-lg py-3 shadow-sm">
                                <i class="fas fa-envelope me-2"></i> Nhận mã qua Email
                            </button>
                            <button type="submit" name="phuongThuc" value="SMS" class="btn btn-outline-primary btn-lg py-3 shadow-sm">
                                <i class="fas fa-sms me-2"></i> Nhận mã qua SMS
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>