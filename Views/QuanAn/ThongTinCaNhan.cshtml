@{
    ViewBag.Title = "Thông Tin Cá Nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy dữ liệu từ ViewBag/Session
    var user = ViewBag.UserRecord; // Đối tượng Khách hàng hoặc Nhân viên
    bool isKH = ViewBag.IsKhachHang ?? true;
    var listDonHang = ViewBag.LichSu as List<DAQCom.Models.HoaDon>;
}

<style>
    .profile-header {
        background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
        padding: 60px 0;
        margin-bottom: 30px;
        color: white;
        border-radius: 0 0 20px 20px;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,0.2);
        border: 4px solid rgba(255,255,255,0.5);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: bold;
    }

    .card-custom {
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .badge-status-0 {
        background: #ffc107;
        color: #000;
    }

    .badge-status-1 {
        background: #17a2b8;
        color: #fff;
    }

    .badge-status-2 {
        background: #28a745;
        color: #fff;
    }

    .badge-status-99 {
        background: #dc3545;
        color: #fff;
    }
</style>

<div class="profile-header text-center">
    <div class="container">
        <div class="avatar-circle mx-auto mb-3">
            @{
                string tenHienThi = isKH ? user.TenKH : user.TenNV;
                string letter = string.IsNullOrEmpty(tenHienThi) ? "U" : tenHienThi.Substring(0, 1).ToUpper();
            }
            @letter
        </div>
        <h3>Xin chào, @tenHienThi</h3>
        <p class="badge bg-light text-dark">@(isKH ? "Hạng: Khách hàng" : "Chức vụ: " + user.ChucVu)</p>
    </div>
</div>

<div class="container mb-5">
    @if (TempData["ThongBao"] != null)
    {<div class="alert alert-success">@TempData["ThongBao"]</div>}
    @if (TempData["Loi"] != null)
    {<div class="alert alert-danger">@TempData["Loi"]</div>}

    <div class="row">
        <div class="col-md-3">
            <div class="card card-custom p-3">
                <div class="nav flex-column nav-pills">
                    <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-info">Thông tin cá nhân</button>
                    @if (isKH)
                    {
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-orders">Lịch sử đơn hàng</button>
                    }
                    <hr />
                    <a href="@Url.Action("DangXuat","QuanAn")" class="nav-link text-danger">Đăng xuất</a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-info">
                    <div class="card card-custom p-4">
                        <h4 class="mb-4">Cập nhật thông tin</h4>
                        @using (Html.BeginForm("CapNhatThongTin", "QuanAn", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ID" value="@(isKH ? user.MaKH : user.MaNV)" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Họ tên</label>
                                    <input name="HoTen" value="@tenHienThi" class="form-control" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email</label>
                                    <input name="Email" value="@user.Email" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">SĐT</label>
                                    <input name="SDT" value="@user.SDT" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Tài khoản</label>
                                    @* ĐÃ SỬA LỖI: Kiểm tra isKH để lấy đúng cột TenDangNhap hoặc TaiKhoan *@
                                    <input value="@(isKH ? user.TenDangNhap : user.TaiKhoan)" class="form-control" disabled />
                                </div>
                                @if (isKH)
                                {
                                    <div class="col-12">
                                        <label class="form-label">Địa chỉ</label>
                                        <input name="DiaChi" value="@user.DiaChi" class="form-control" />
                                    </div>
                                }
                                <div class="col-12 text-end">
                                    <button class="btn btn-primary px-4">Lưu thay đổi</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (isKH)
                {
                    <div class="tab-pane fade" id="tab-orders">
                        <div class="card card-custom p-4">
                            <h4 class="mb-3">Lịch sử đơn hàng</h4>
                            @if (listDonHang != null && listDonHang.Any())
                            {
                                <div class="accordion" id="accDon">
                                    @foreach (var hd in listDonHang)
                                    {
                                        int status = hd.TrangThai ?? 0;
                                        string badgeClass = status == 0 ? "badge-status-0" : status == 1 ? "badge-status-1" : status == 2 ? "badge-status-2" : "badge-status-99";

                                        <div class="accordion-item mb-2">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#hd_@hd.MaHD">
                                                    <strong>#@hd.MaHD</strong>
                                                    <span class="ms-2 text-muted small">@string.Format("{0:dd/MM/yyyy HH:mm}", hd.NgayDat)</span>
                                                    <span class="badge ms-3 @badgeClass">
                                                        @(status == 0 ? "Chờ duyệt" : status == 1 ? "Đang giao" : status == 2 ? "Hoàn tất" : "Đã hủy")
                                                    </span>
                                                    <span class="ms-auto text-danger fw-bold">@((hd.TongTien ?? 0).ToString("N0")) đ</span>
                                                </button>
                                            </h2>
                                            <div id="hd_@hd.MaHD" class="accordion-collapse collapse" data-bs-parent="#accDon">
                                                <div class="accordion-body">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        @if (status == 0)
                                                        {<button class="btn btn-outline-danger btn-sm" onclick="huyDon(@hd.MaHD)">Hủy đơn</button>}
                                                        <a href="@Url.Action("DatLai","QuanAn",new { id = hd.MaHD })" class="btn btn-primary btn-sm">Đặt lại</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-center text-muted py-5">Bạn chưa có đơn hàng nào.</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>