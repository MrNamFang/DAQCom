@model DAQCom.Models.KhachHang
@{ ViewBag.Title = "Khôi phục mật khẩu"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0" style="border-radius: 15px;">
                <div class="card-body p-4 text-center">
                    <h3 class="fw-bold mb-3">KHÔI PHỤC MẬT KHẨU</h3>
                    <p class="text-muted small mb-4">Nhập <b>Tên đăng nhập</b> để tìm thông tin xác thực.</p>

                    @if (ViewBag.Error != null)
                    {<div class="alert alert-danger py-2 small">@ViewBag.Error</div>}

                    @using (Html.BeginForm("QuenMatKhau", "QuanAn", FormMethod.Post))
                    {
                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold small">Tên đăng nhập</label>
                            <input type="text" name="TenTaiKhoan" class="form-control" required placeholder="Ví dụ: khach123" />
                        </div>
                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2 shadow-sm">TÌM TÀI KHOẢN</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>