@using DAQCom.Models
@{
    ViewBag.Title = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // --- QUAN TRỌNG: Ép kiểu an toàn ---
    // Nếu ViewBag.KetQua null thì tạo list rỗng để tránh crash
    var ketQua = ViewBag.KetQua as List<MonAn> ?? new List<MonAn>();
    string tuKhoa = ViewBag.TuKhoa as string;
}

<div class="container py-5">
    <h2 class="text-center mb-4 text-uppercase fw-bold text-primary">
        🔍 KẾT QUẢ TÌM KIẾM
    </h2>

    @if (!string.IsNullOrEmpty(tuKhoa))
    {
        <p class="text-center text-muted fs-5">Từ khóa: <strong>"@tuKhoa"</strong></p>
    }

    <hr class="mb-5" />

    @if (ketQua.Count > 0)
    {
        <h4 class="text-success mb-4"><i class="bi bi-check-circle-fill"></i> Tìm thấy @ketQua.Count món ăn phù hợp.</h4>

        <div class="row">
            @foreach (var item in ketQua)
            {
                // Xử lý ảnh
                string imgPath = string.IsNullOrEmpty(item.HinhAnh)
                                 ? "~/Content/Images/noimage.jpg"
                                 : "~/Content/Images/" + item.HinhAnh;

                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 hover-effect">
                        <div class="overflow-hidden position-relative">
                            <img src="@Url.Content(imgPath)"
                                 class="card-img-top"
                                 style="height: 180px; object-fit: cover; transition: transform 0.3s;"
                                 onerror="this.src='@Url.Content("~/Content/Images/noimage.jpg")'"
                                 alt="@item.TenMon" />
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate fw-bold" title="@item.TenMon">
                                <a href="@Url.Action("ChiTiet", "QuanAn", new { id = item.MaMon })" class="text-decoration-none text-dark">
                                    @item.TenMon
                                </a>
                            </h5>

                            <p class="card-text text-muted small flex-grow-1">
                                @(string.IsNullOrEmpty(item.MoTa) ? "Đang cập nhật..." : (item.MoTa.Length > 50 ? item.MoTa.Substring(0, 50) + "..." : item.MoTa))
                            </p>

                            <p class="card-text text-danger fw-bold fs-5">
                                @(item.Gia.HasValue ? item.Gia.Value.ToString("N0") : "Liên hệ") đ
                            </p>

                            @* --- ĐÃ THÊM NÚT XEM CHI TIẾT --- *@
                        <div class="d-grid gap-2 mt-auto">
                            <a href="@Url.Action("ChiTiet", "QuanAn", new { id = item.MaMon })"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-eye"></i> Xem Chi Tiết
                            </a>

                            <a href="#" class="btn btn-warning btn-sm fw-bold text-dark btn-add-cart"
                               data-id="@item.MaMon">
                                <i class="bi bi-cart-plus-fill"></i> Thêm vào Giỏ
                            </a>

                        </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        // Hiển thị khi không có kết quả
        if (!string.IsNullOrEmpty(tuKhoa))
        {
            <div class="alert alert-warning text-center py-5 shadow-sm" role="alert">
                <i class="bi bi-search display-1 text-muted mb-3 d-block"></i>
                <h4 class="alert-heading fw-bold">Không tìm thấy kết quả nào!</h4>
                <p class="mb-4">Rất tiếc, chúng tôi không tìm thấy món ăn nào phù hợp với từ khóa <strong>"@tuKhoa"</strong>.</p>
                <a href="@Url.Action("DatMon", "QuanAn")" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
                    <i class="bi bi-book-half me-2"></i> Xem toàn bộ thực đơn
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted mb-3 d-block"></i>
                <p class="text-muted fs-5">Vui lòng nhập tên món ăn để bắt đầu tìm kiếm.</p>
            </div>
        }
    }
</div>

<style>
    .hover-effect:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

        .hover-effect:hover img {
            transform: scale(1.05);
        }
</style>