@{
    ViewBag.Title = "Liên hệ | Quán Ăn Ngon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center text-info">Liên hệ với chúng tôi</h2>
    <hr />
    <p>Nếu bạn có bất kỳ câu hỏi nào, vui lòng gửi thông tin liên hệ của bạn cho chúng tôi:</p>

    <form>
        <div class="form-group">
            <label>Họ và tên:</label>
            <input type="text" class="form-control" placeholder="Nhập họ tên của bạn" />
        </div>
        <div class="form-group">
            <label>Email:</label>
            <input type="email" class="form-control" placeholder="Nhập email" />
        </div>
        <div class="form-group">
            <label>Nội dung:</label>
            <textarea class="form-control" rows="4" placeholder="Nội dung liên hệ"></textarea>
        </div>
        <button type="submit" class="btn btn-primary mt-2">Gửi liên hệ</button>
    </form>

    <hr />
    <p><strong>Địa chỉ:</strong> 123 Nguyễn Huệ, Quận 1, TP.HCM</p>
    <p><strong>Điện thoại:</strong> 0909 123 456</p>
    <p><strong>Email:</strong> lienhe@quanngon.vn</p>
</div>