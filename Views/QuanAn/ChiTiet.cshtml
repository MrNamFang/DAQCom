@using DAQCom.Models
@model MonAn

@{
    ViewBag.Title = Model.TenMon + " - Chi Tiết";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Xử lý đường dẫn ảnh
    string imgPath = string.IsNullOrEmpty(Model.HinhAnh)
                     ? "~/Content/Images/noimage.jpg"
                     : "~/Content/Images/" + Model.HinhAnh;
}

<div class="container py-5">

    @* --- ĐÃ XÓA PHẦN TRANG CHỦ / THỰC ĐƠN Ở ĐÂY --- *@

    <div class="row">
        @* --- CỘT TRÁI: HÌNH ẢNH --- *@
        <div class="col-md-6 mb-4">
            <div class="card shadow border-0">
                <img src="@Url.Content(imgPath)"
                     onerror="this.src='@Url.Content("~/Content/Images/noimage.jpg")'"
                     class="img-fluid rounded"
                     alt="@Model.TenMon"
                     style="width: 100%; height: 400px; object-fit: cover;" />
            </div>
        </div>

        @* --- CỘT PHẢI: THÔNG TIN --- *@
        <div class="col-md-6">
            <h2 class="fw-bold text-primary mb-3">@Model.TenMon</h2>

            <p class="mb-3">
                <span class="badge bg-warning text-dark fs-6">@Model.LoaiMon</span>
            </p>

            <h3 class="text-danger fw-bold mb-4">
                @Model.Gia.Value.ToString("N0") VNĐ
            </h3>

            <div class="mb-4">
                <h5 class="fw-bold text-dark border-bottom pb-2">Mô tả món ăn:</h5>
                <p class="text-muted" style="line-height: 1.8;">
                    @(string.IsNullOrEmpty(Model.MoTa) ? "Món ăn chưa có mô tả chi tiết." : Model.MoTa)
                </p>
            </div>

            <hr />

            <div class="d-flex gap-3 mt-4">
                @* Nút thêm vào giỏ *@
                <a href="#" class="btn btn-warning btn-lg fw-bold px-4 btn-add-cart"
                   data-id="@Model.MaMon">
                    <i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ
                </a>


                @* Nút quay lại *@
                <a href="@Url.Action("DatMon", "QuanAn")" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-arrow-left"></i> Quay lại thực đơn
                </a>
            </div>
        </div>
    </div>
</div>