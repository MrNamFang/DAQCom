@model DAQCom.Models.HoaDon

<div class="bill-header">
    <i class="fas fa-receipt me-2"></i> Món Đã Gọi
</div>

<div class="bill-list">
    @if (Model != null && Model.ChiTietHoaDons != null && Model.ChiTietHoaDons.Count > 0)
    {
        <table class="table table-hover m-0 bill-table">
            <thead>
                <tr>
                    <th class="ps-3">Tên món</th>
                    <th class="text-center" style="width: 50px;">SL</th>
                    <th class="text-end pe-3">Tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ct in Model.ChiTietHoaDons)
                {
                    string rowClass = (ct.TrangThaiMon == -1) ? "row-new" : "";
                    <tr class="@rowClass">
                        <td class="ps-3 text-dark">
                            <div class="fw-bold">@ct.MonAn.TenMon</div>
                            @if (ct.TrangThaiMon == -1)
                            {
                                <span class="badge bg-warning text-dark" style="font-size:0.65rem">Mới</span>
                            }
                            else
                            {
                                <span class="badge bg-success" style="font-size:0.65rem">Đã gửi</span>
                            }

                            @if (!string.IsNullOrEmpty(ct.GhiChu))
                            { <br /><small class="text-muted fst-italic">(@ct.GhiChu)</small>}
                        </td>
                        <td class="text-center fw-bold text-primary">@ct.SoLuong</td>
                        <td class="text-end pe-3 fw-bold">@string.Format("{0:N0}", ct.DonGia * ct.SoLuong)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center text-muted mt-5 px-4">
            <i class="fas fa-utensils fa-4x mb-3 text-secondary opacity-25"></i>
            <h5>Bàn trống</h5>
            <p class="small">Vui lòng chọn món bên trái.</p>
        </div>
    }
</div>

<div class="bill-footer">
    <div class="d-flex justify-content-between mb-3 align-items-end">
        <span class="fw-bold text-secondary">TỔNG TẠM TÍNH:</span>
        <span class="fw-bold text-danger fs-3 lh-1">@string.Format("{0:N0} đ", Model?.TongTien ?? 0)</span>
    </div>
    <div class="d-grid gap-2">
        @{
            bool coMonMoi = Model != null && Model.ChiTietHoaDons.Any(c => c.TrangThaiMon == -1);
        }

        @if (coMonMoi)
        {
            <button class="btn btn-warning fw-bold py-3 shadow-sm" onclick="guiBep()">
                <i class="fas fa-fire-burner me-2"></i> GỬI BẾP & IN PHIẾU
            </button>
        }
        else if (Model != null && Model.TongTien > 0)
        {
            if (Model.TrangThai == 1)
            {
                <div class="alert alert-warning text-center mb-0 py-2 fw-bold shadow-sm border-warning">
                    <i class="fas fa-clock fa-spin me-2"></i> Đang chờ thu ngân...
                </div>
            }
            else
            {
                <button class="btn btn-primary fw-bold py-2 shadow-sm" onclick="guiYeuCauThanhToan()">
                    <i class="fas fa-paper-plane me-2"></i> GỬI YÊU CẦU TT
                </button>
            }
        }
        else
        {
            <button class="btn btn-secondary fw-bold py-3" disabled>
                <i class="fas fa-ban me-2"></i> CHƯA CÓ ĐƠN
            </button>
        }
    </div>
</div>