@using DAQCom.Models
@model List<DAQCom.Models.GioHang>

@{
    ViewBag.Title = "Giỏ hàng của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Ép kiểu an toàn từ ViewBag (double) sang decimal để hiển thị tiền tệ
    double tongTienDouble = (double)(ViewBag.TongTien ?? 0.0);
    decimal TongTien = Convert.ToDecimal(tongTienDouble);
}

<div class="container py-5">
    @* Sửa thông báo lỗi/thành công từ Controller *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <h2 class="text-center text-uppercase mb-4 fw-bold text-danger" style="border-bottom: 3px solid #ffc107; display: inline-block; padding-bottom: 5px;">GIỎ HÀNG CỦA BẠN</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning text-center py-5 shadow-sm" role="alert">
            <i class="bi bi-cart-x display-1 text-muted mb-3 d-block"></i>
            <h4 class="alert-heading fw-bold">Giỏ hàng đang trống!</h4>
            <p class="mb-4">Bạn chưa chọn món ăn nào. Hãy quay lại thực đơn để chọn món nhé.</p>
            <a href="@Url.Action("DatMon", "QuanAn")" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
                <i class="bi bi-arrow-left me-2"></i> Quay lại Thực Đơn
            </a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center mb-0">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th class="py-3">Món ăn</th>
                                <th class="py-3">Đơn giá</th>
                                <th class="py-3" style="width: 150px;">Số lượng</th>
                                <th class="py-3">Thành tiền</th>
                                <th class="py-3">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                string imgPath = string.IsNullOrEmpty(item.sAnh) ? "~/Content/Images/noimage.jpg" : "~/Content/Images/" + item.sAnh;
                                // Ép kiểu an toàn vì item.dDonGia là double
                                decimal donGia = Convert.ToDecimal(item.dDonGia);
                                int soLuong = item.iSoLuong;
                                decimal thanhTien = Convert.ToDecimal(item.dThanhTien);

                                <tr>
                                    <td class="text-start ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@Url.Content(imgPath)" class="rounded me-3" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='@Url.Content("~/Content/Images/noimage.jpg")'" />
                                            <span class="fw-bold text-dark">@item.sTenMon</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">@donGia.ToString("N0") đ</td>
                                    <td>
                                        @* Form cập nhật số lượng - QUAN TRỌNG: SỬ DỤNG MaMon *@
                                        @using (Html.BeginForm("CapNhatGioHang", "GioHang", new { maMon = item.iMaMon }, FormMethod.Post))
                                        {
                                            <div class="input-group input-group-sm justify-content-center" style="width: 120px; margin: 0 auto;">
                                                <input type="number" min="1" name="txtSoLuong" value="@soLuong" class="form-control text-center fw-bold" />
                                                <button type="submit" class="btn btn-outline-secondary" title="Cập nhật"><i class="bi bi-arrow-repeat"></i></button>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold text-danger">@thanhTien.ToString("N0") đ</td>
                                    <td>
                                        @* Nút xóa từng món - QUAN TRỌNG: SỬ DỤNG MaMon *@
                                        <a href="@Url.Action("XoaGioHang", "GioHang", new { maMon = item.iMaMon })" class="btn btn-outline-danger btn-sm rounded-circle" onclick="return confirm('Bạn có chắc muốn xóa món này?');" title="Xóa món">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="row align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <a href="@Url.Action("DatMon", "QuanAn")" class="btn btn-outline-secondary fw-bold">
                    <i class="bi bi-arrow-left me-2"></i> Tiếp tục mua hàng
                </a>
                @* Nút xóa tất cả *@
                <a href="@Url.Action("XoaTatCaGioHang", "GioHang")" class="btn btn-outline-danger fw-bold ms-2" onclick="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?');">
                    <i class="bi bi-trash me-2"></i> Xóa tất cả
                </a>
            </div>
            <div class="col-md-6 text-md-end">
                <div class="d-inline-block text-end me-3">
                    <p class="mb-0 text-muted">Tổng cộng:</p>
                    <h3 class="fw-bold text-danger m-0">@TongTien.ToString("N0") đ</h3>
                </div>
                @* Nút thanh toán *@
                <a href="@Url.Action("DatHang", "GioHang")" class="btn btn-warning btn-lg fw-bold px-5 rounded-pill shadow-sm">
                    Tiến hành Thanh Toán <i class="bi bi-credit-card-2-front ms-2"></i>
                </a>
            </div>
        </div>
    }
</div>