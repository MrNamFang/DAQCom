@model DAQCom.Models.DatBan
@{
    ViewBag.Title = "Đặt Bàn Trước";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-white text-center py-3">
                    <h3 class="mb-0 fw-bold text-uppercase"><i class="bi bi-calendar-check me-2"></i>Đặt Bàn Giữ Chỗ</h3>
                </div>
                <div class="card-body p-4 bg-light">

                    @using (Html.BeginForm("Index", "DatBan", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                @Html.EditorFor(model => model.HoTen, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập tên của bạn", @required = "required" } })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                @Html.EditorFor(model => model.SDT, new { htmlAttributes = new { @class = "form-control", @placeholder = "Số để nhà hàng liên hệ", @required = "required", @type = "number" } })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Ngày đến ăn <span class="text-danger">*</span></label>
                                <input type="date" name="NgayDenInput" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Giờ đến <span class="text-danger">*</span></label>
                                <input type="time" name="GioDenInput" class="form-control" required />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Số lượng khách <span class="text-danger">*</span></label>
                                @Html.EditorFor(model => model.SoNguoi, new { htmlAttributes = new { @class = "form-control", @type = "number", @min = "1", @max = "50", @Value = "2" } })
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Ghi chú (Yêu cầu đặc biệt)</label>
                                @Html.TextAreaFor(model => model.GhiChu, new { @class = "form-control", @rows = "3", @placeholder = "Ví dụ: Ngồi gần cửa sổ, cần ghế trẻ em..." })
                            </div>

                            <div class="col-12 mt-4 text-center">
                                <button type="submit" class="btn btn-warning btn-lg px-5 rounded-pill fw-bold text-white shadow">
                                    Xác Nhận Đặt Bàn
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>